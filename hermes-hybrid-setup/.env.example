# Hermes Hybrid Setup — copy to .env and fill in (never commit .env)
#   cp .env.example .env
# Git Bash path style: D:/hermes-agent-project/hermes-hybrid-setup

# --- Online main model (optional — set ONLINE_MODEL_SKIP=true to defer) ---
ONLINE_MODEL_SKIP=false
ONLINE_MODEL_PROVIDER=openrouter
ONLINE_MODEL_API_KEY=your-online-api-key-here
ONLINE_MODEL_NAME=anthropic/claude-sonnet-4

# --- Local coder model (primary offline workhorse) ---
LOCAL_MODEL_BASE_URL=http://127.0.0.1:11434/v1
LOCAL_MODEL_NAME=qwen2.5-coder:14b

# --- Local Gemma helper (fast private tasks, summaries) ---
LOCAL_GEMMA_BASE_URL=http://127.0.0.1:11434/v1
LOCAL_GEMMA_MODEL_NAME=gemma2:9b

# --- Workspace & profile ---
HERMES_WORKSPACE_ROOT=D:/hermes-agent-project/hermes-hybrid-setup
DEFAULT_PROJECT_PROFILE=commerceos-dev-agent
ACTIVE_PROFILE_FILE=ACTIVE_PROFILE

# --- Safety gates (keep false unless you explicitly override in a reviewed session) ---
ENABLE_DOCKER_SANDBOX=true
ALLOW_GIT_PUSH=false
ALLOW_PRODUCTION_DB=false
ALLOW_DESTRUCTIVE_COMMANDS=false

# --- Test toggles ---
# Set to 1 until Ollama/LM Studio is running with LOCAL_MODEL_NAME
SKIP_LOCAL_MODEL_TEST=0

# --- Budget hints (enforced by budget-gatekeeper skill + budget-policy.yaml) ---
MONTHLY_BUDGET_USD=20
DAILY_BUDGET_USD=2

# Optional: map into Hermes .env when you run hermes setup (see docs/MODEL_SETUP.md)
# OPENROUTER_API_KEY=${ONLINE_MODEL_API_KEY}
# HERMES_HOME=D:/hermes-agent-project/.hermes-hybrid
