# === Secrets and environment ===
.env
.env.*
!.env.example
ACTIVE_PROFILE
*.key
*.pem
*.p12
*.pfx

# === Runtime logs (keep directory via .gitkeep) ===
logs/*
!logs/.gitkeep
*.log

# === Local RAG index (per profile, never commit) ===
memories/**/.rag-index/

# === Hermes runtime ===
.hermes/
.hermes-local/
configs/*.local.yaml

# === Model and cache files ===
models/
ollama/
*.gguf
*.safetensors
.cache/
tmp/
.temp/

# === Build / dist ===
dist/
build/
node_modules/

# === Python ===
.venv/
venv/
__pycache__/
*.pyc

# === Workspace runtime (per-project) ===
workspaces/**/scratch/
workspaces/**/.cache/
workspaces/**/node_modules/
workspaces/*/.env

# === Learning memory exports (local only) ===
memories/**/exports/*.jsonl
memories/**/do-not-ingest/*
!memories/**/do-not-ingest/.gitkeep

# === Evaluations private data ===
evaluations/*/
!evaluations/.gitkeep
evaluations/*/raw-secrets/
api-spend-private/

# === OS / editor ===
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/
